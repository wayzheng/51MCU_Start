   1          #include <REGX52.H>
   2          
   3          /**
   4            *@brief  定时器0初始化，1ms中断一次
   5            *@param  无
   6            *@retval 无
   7            */
   8          void Timer0_Init(void)
   9          {
  10   1          // 配置 Timer0 为模式1，16位定时器
  11   1          TMOD &= 0xF0;    // 清除 Timer0 的控制位，保留 Timer1
  12   1          TMOD |= 0x01;    // Timer0 工作在模式1
  13   1      
  14   1          // 定时 1ms，假设晶振 12MHz，传统 12T 模式
  15   1          TH0 = (65536 - 1000) / 256;
  16   1          TL0 = (65536 - 1000) % 256;
  17   1      
  18   1          TF0 = 0;         // 清除溢出标志
  19   1          TR0 = 1;         // 启动 Timer0
  20   1      
  21   1          ET0 = 1;         // 允许 Timer0 中断
  22   1          EA  = 1;         // 开启总中断
  23   1          PT0 = 0;         // Timer0 中断优先级低
  24   1      }
  25          
