  38          
  39          void Timer0_SetCounter(unsigned int Value) {
  40   1        TH0 = Value / 256;
  41   1        TL0 = Value % 256;
  42   1        
  43   1      }
  44          unsigned int Timer0_GetCounter(void) {
  45   1        return ((TH0<<8) | TL0);
  46   1      }
  47          
  48          void Timer0_Run(unsigned char Flag) {
  49   1        TR0 = Flag; 
  50   1      }


