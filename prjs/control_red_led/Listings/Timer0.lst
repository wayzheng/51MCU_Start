   1          #include <REGX52.H>
   2          /**
   3            *@brief 定时器初始化 1ms
   4            *@param 无
   5            *@retvel 无
   6            */
   7          void Timer0_Init(){
   8   1        // TMOD进行配置 来对定时器的模式来进行配置 工作在模式1
   9   1        // TMOD = 0x01; // 0000_0001
  10   1        TMOD = TMOD & 0xF0; // 将TMOD的低四位清零 并将高四位进行保持不变
  11   1        TMOD = TMOD | 0x01; // 前七位保持不变，将最后的一位变为1
  12   1        // 上面两句实现了将TMOD置为0x01的操作 因为TMOD只支持段寻址不支持位寻址
  13   1        // 对TCON来进行配置 对timer来进行配置
  14   1        TF0 = 0; // 清除TF0标志
  15   1        TR0 = 0; // 定时器0不进行计时操作
  16   1        TL0 = 0x66; // 得到高位
  17   1        TH0 = 0xFC; // 得到低位
  18   1      //  
  19   1      //  ET0 = 1; // 允许中断
  20   1      //  EA = 1;  // 允许总中断
  21   1      //  PT0 = 0; // 中断优先级为0
  22   1        
  23   1      }
  24          
  25          // 定时器模版
  26          /*
  27          void Timer0_Routine() interrupt 1{
  28            static unsigned int T0Count = 0; // 保证退出函数的时候不丢失数据
  29            TH0 = 64535 / 256; // 重新赋初始值
  30            TL0 = 64535 % 256;
  31            T0Count++;
  32            if (T0Count >= 1000) {
  33              P2_0 = ~P2_0;
  34              T0Count = 0;
  35            }
  36          }
