   1          #include <REGX52.H>
   2          /**
   3          *@brief 串口初始化 波特率为4800 @ 11.0592Mhz
   4            *@param 无
   5            *@retvel 无
   6            */
   7          void UART_Init() {
   8   1        SCON = 0x50;
   9   1        PCON |= 0x80;   //使能波特率倍速位SMOD
  10   1        // uart只能对定时器1
  11   1        // TMOD进行配置 来对定时器的模式来进行配置 工作在模式1
  12   1        // TMOD = 0x01; // 0000_0001
  13   1        TMOD = TMOD & 0x0F; // 工作再模式1的配置
  14   1        TMOD = TMOD | 0x20; // 
  15   1        // 上面两句实现了将TMOD置为0x01的操作 因为TMOD只支持段寻址不支持位寻址
  16   1        // 对TCON来进行配置 对timer来进行配置
  17   1        // TF0  = 0; // 清除TF0标志
  18   1        // TR0 = 1; // 定时器从0开始计时
  19   1        // TH0 = 64535 / 256; // 得到高位
  20   1        // TL0 = 64535 % 256 + 1; // 得到低位
  21   1        TL1 = 0xF4;     //设置定时初始值
  22   1        TH1 = 0xF4;     //设置定时重载值 
  23   1        // ET0 = 1; // 允许中断
  24   1        // EA = 1;  // 允许总中断
  25   1        PT0 = 0; // 中断优先级为0
  26   1        ET1 = 0;      //禁止定时器中断
  27   1        TR1 = 1;      //定时器1开始计时
  28   1        ES = 1;
  29   1        EA = 1;
  30   1      }
  31          
  32          /**
  33            *@brief 串口发送一个字节数据
  34            *@param Byte 8bits 就是要发送的一个字节的数据
  35            *@retvel 无
  36            */
  37          void UART_SendByte(unsigned char Byte) {
  38   1        SBUF = Byte;
  39   1        while(TI == 0);
  40   1        TI = 0;
  41   1      }


